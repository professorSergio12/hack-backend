# Server
PORT=4000

# Zoho OAuth (generate via Zoho API Console)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
ZOHO_API_REGION=in
ZOHO_REDIRECT_URI=http://localhost:4000/oauth/callback

# Zoho Creator app
ZOHO_CREATOR_OWNER=your_zoho_username
ZOHO_CREATOR_APP=YOUR_APP_LINK_NAME
ZOHO_CREATOR_REPORT=STS_Operation_Report
ZOHO_REFERENCE_FIELD=Reference_Number

# Optional: API key for external forms to authenticate
API_KEY=change-me-in-production
